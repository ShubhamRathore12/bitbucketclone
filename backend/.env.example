# =============================================================================
# GitForge Backend Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# Server
SERVER_PORT=3000
SERVER_ENV=development  # development | staging | production

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=gitforge
DB_PASSWORD=changeme
DB_NAME=gitforge
DB_POOL_SIZE=20
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=replace-with-a-64-char-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Git storage
GIT_BASE_PATH=/data/repos

# AI (Claude)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
